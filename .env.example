# Production requires an API token. Do not expose this value in the frontend.
ADMIN_API_KEY=
CORS_ORIGIN=https://your-domain.vercel.app

# Use Supabase for persistent production storage. Do not use the service-role key
# unless requests are authenticated by a trusted backend.
SUPABASE_URL=
SUPABASE_KEY=

# Optional: used only for local development against a protected API.
VITE_API_TOKEN=
