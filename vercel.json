{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/status",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1",
      "headers": {
        "cache-control": "no-cache"
      }
    }
  ]
}
